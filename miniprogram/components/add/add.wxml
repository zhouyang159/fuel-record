<view class="add-form">
  <view class="date-time-row">
    <picker mode="date" value="{{record.date}}" bindchange="onDateChange">
      加油时间：{{record.date}}
    </picker>
    <picker class="time-picker" mode="time" value="{{record.time}}" bindchange="onTimeChange">
      {{record.time}}
    </picker>
  </view>

  <view class="mileage-row">
    <text class="row-label">当前里程：</text>
    <input class="input mileage-input" value="{{record.mileage}}" type="number" bindinput="onMileageChange" />
  </view>

  <view class="calc-row">
    <view class="calc-field">
      <text class="field-label">机显单价</text>
      <input class="input" value="{{record.price}}" type="digit" bindinput="onPriceChange" />
    </view>
    <view class="operator-badge" aria-label="multiply">
      <van-icon name="cross" size="20rpx" color="#1989fa" />
    </view>
    <view class="calc-field">
      <text class="field-label">加油量</text>
      <input class="input" value="{{record.quantity}}" type="digit" bindinput="onQuantityChange" />
    </view>
    <view class="operator-badge" aria-label="result">
      <van-icon name="arrow" size="20rpx" color="#1989fa" />
    </view>
    <view class="calc-field">
      <text class="field-label">机显金额</text>
      <input class="input" value="{{record.pay}}" type="digit" bindinput="onPayChange" />
    </view>
  </view>

  <view class="calc-row second-row plain-row">
    <view class="calc-field">
      <text class="field-label">实际单价</text>
      <input class="input disabled" disabled="{{true}}" value="{{record.realPrice}}" type="digit" bindinput="onRealPriceChange" />
    </view>
    <view class="calc-field">
      <text class="field-label">优惠金额</text>
      <input class="input" value="{{record.discountAmount}}" type="digit" bindinput="onDiscountAmountChange" />
    </view>
    <view class="calc-field">
      <text class="field-label">实付金额</text>
      <input class="input" value="{{record.realPay}}" type="digit" bindinput="onRealPayChange" />
    </view>
  </view>

  <view>
    <view class="toggle-row toggle-row-first">
      <text class="toggle-label">是否加满？</text>
      <view class="toggle-actions">
        <button bindtap="setAddFull" data-value="true" type="{{ record.isAddFull ? 'primary' : 'default'}}" size="mini">加满</button>
        <button bindtap="setAddFull" data-value="false" type="{{ record.isAddFull ? 'default' : 'primary'}}" size="mini">没加满</button>
      </view>
    </view>

    <view class="toggle-row">
      <text class="toggle-label">油量警告灯亮了吗？</text>
      <view class="toggle-actions">
        <button bindtap="setWarningLight" data-value="true" type="{{ record.isWarningLight ? 'primary' : 'default'}}" size="mini">油灯亮</button>
        <button bindtap="setWarningLight" data-value="false" type="{{ record.isWarningLight ? 'default' : 'primary'}}" size="mini">没有亮</button>
      </view>
    </view>
  </view>
</view>
