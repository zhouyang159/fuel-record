
<view>
  <view style="margin-bottom: 10rpx; display: flex">
    <picker mode="date" value="{{record.date}}" bindchange="onDateChange">
        加油时间：{{record.date}} 
    </picker>
    <picker style="margin-left: 10rpx" mode="time" value="{{record.time}}" bindchange="onTimeChange">
        {{record.time}}
    </picker>
  </view>
  
  <view style="margin-top:20rpx; display: flex;">
    当前里程：<input style="flex: 1" class="input" value="{{record.mileage}}" type="number" bindinput="onMileageChange" />
  </view>

  <view style="margin-top: 20rpx; display: flex; align-items: center;">
    <view>实际单价：<input disabled class="input" value="{{record.price}}" type="digit" bindinput="onPriceChange" /></view>
    <view style="margin: 0 20rpx;">x</view>
    <view>加油量：<input class="input" value="{{record.quantity}}" type="digit" bindinput="onQuantityChange" /></view>
    <view style="margin: 0 20rpx;">=</view>
    <view>实付金额：<input class="input" value="{{record.pay}}" type="digit" bindinput="onPayChange" /></view>
  </view>

  <view>
    <view style="display: flex;margin-top: 20rpx;">
      <view>是否加满？</view>
      <view>
        <button bindtap="setAddFull" data-value="true" type="{{ record.isAddFull ? 'primary' : 'default'}}" size="mini">加满</button>
        <button bindtap="setAddFull" data-value="false" type="{{ record.isAddFull ? 'default' : 'primary'}}" size="mini">没加满</button>
      </view>
    </view>

    <view style="display: flex; margin-top: 20rpx;">
      <view>油量警告灯亮了吗？</view>
      <view>
        <button bindtap="setWarningLight" data-value="true" type="{{ record.isWarningLight ? 'primary' : 'default'}}" size="mini">油灯亮</button>
        <button bindtap="setWarningLight" data-value="false" type="{{ record.isWarningLight ? 'default' : 'primary'}}" size="mini">没有亮</button>
      </view>
    </view>
  </view>
</view>