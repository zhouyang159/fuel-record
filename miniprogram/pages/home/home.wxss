/**index.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}
.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.delete_btn {
  width: 80px;
  height: 100%;
  background: red;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-header {
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.current-car-trigger {
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
}

.header-add-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.car-popup {
  width: 100%;
  background: #fff;
  padding: 24rpx;
  box-sizing: border-box;
}

.car-popup-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.car-popup-list {
  max-height: 500rpx;
  overflow-y: auto;
}

.car-popup-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.car-popup-item-active {
  color: #1989fa;
  font-weight: 600;
}

.car-popup-empty {
  text-align: center;
  color: #999;
  padding: 24rpx 0;
}

.car-popup-actions {
  margin-top: 20rpx;
  display: flex;
  justify-content: flex-end;
}

.car-popup-actions-right {
  margin-left: 16rpx;
}

/* 统计面板样式 */
.summary-board {
  background: linear-gradient(135deg, #f8f8f8 0%, #efefef 100%);
  border-radius: 12rpx;
  padding: 18rpx 16rpx;
  margin-bottom: 12rpx;
}

.summary-year-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.summary-year {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.summary-stats-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.summary-stat {
  flex: 1;
  text-align: center;
}

.summary-stat-value {
  font-size: 26rpx;
  color: #666;
  display: block;
  line-height: 1.4;
}


.content-wrap {
  padding: 14rpx;
}

.tips-banner {
  display: flex;
  align-items: center;
  background: beige;
  border-radius: 10rpx;
  margin-top: 12rpx;
  padding: 8rpx 10rpx;
}

.records-wrap {
  margin-top: 12rpx;
}

.record-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.record-card {
  flex: 1;
  border: 1rpx solid gray;
  border-radius: 10rpx;
  padding: 8rpx;
}

.record-footer {
  margin-top: 8rpx;
  border-radius: 10rpx;
  padding: 8rpx;
  display: flex;
  justify-content: space-between;
  background-color: rgb(230, 245, 240);
}

/* 年份选择器样式 */
.year-selector-container {
  margin-top: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.year-selector-title {
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.year-labels-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.year-label {
  width: calc(25% - 12rpx);
  padding: 16rpx 0;
  text-align: center;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.year-label-active {
  background: #1989fa;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(25, 137, 250, 0.3);
}

.year-picker-view {
  height: 300rpx;
  width: 100%;
}

.year-picker-item {
  text-align: center;
  line-height: 60rpx;
  font-size: 28rpx;
  color: #333;
}

/* 卡片序号 */
.record-index {
  top: 10rpx;
  left: 10rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  background-color: #1989fa;
  color: #fff;
  border-radius: 20rpx;
  text-align: center;
  font-size: 24rpx;
  z-index: 10;
  margin-right: 10rpx;
}
