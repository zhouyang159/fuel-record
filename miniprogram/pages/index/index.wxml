<!--index.wxml-->
<scroll-view class="scrollarea" scroll-y>
  <view style="padding: 20rpx;">

    <!-- 新增模块 -->
    <view style="border: 1rpx solid gray; border-radius: 10rpx; padding: 10rpx;">
      <add
        record="{{newRecord}}"
        bind:onRecordChange="onRecordChange"
      />
      <view style="margin-top: 10rpx;">
        <button bindtap="addRecord" type="default" plain="true">保存</button>
      </view>
    </view>

    <view style="display: flex; background: beige; padding: 5rpx;border-radius: 10rpx; margin-top: 20rpx;">
      <icon type="info"></icon>
      <view>
        需要两次加满才能计算出油耗
      </view>
    </view>
    
    <!-- 显示模块 -->
    <view style="margin-top: 20rpx;">
      <view>
        <view
          wx:key="index"
          wx:for="{{showCardArr}}"
          style="border: 1rpx solid gray; border-radius: 10rpx; padding: 10rpx; margin-bottom: 10rpx;"
          data-index="{{index}}"
          bind:tap="toModifyPage"
        >
          <view style="display: flex; justify-content: flex-end">
            <icon type="cancel" catchtap="deleteRecord" data-id="{{item.id}}"></icon>
          </view>
          <view style="display: flex; justify-content: space-between;">
            <view>
              {{item.date}} {{item.time}}
            </view>
            <view>
              {{item.fuleConsumption}}升/百公里
            </view>
            <view>
              {{item.mileage}}公里
            </view>
          </view>

          <view style="background-color: rgb(242, 242, 242);">
            <view style="display: flex; justify-content: space-between;">
              <view>
                {{item.pay}}元
              </view>
              <view>
                {{item.price}}元/升
              </view>
              <view>
                +{{item.quantity}}升
              </view>
            </view>
            <view style="display: flex;">
              <view wx:if="{{item.isAddFull}}" style="color: red;">加满</view>
              <view wx:if="{{item.isWarningLight}}" style="color: red; margin-left: 10rpx;">灯亮</view>
            </view>
          </view>

          <view
            style="margin-top: 10rpx; border-radius: 10rpx; padding: 10rpx; display: flex; justify-content: space-between; background-color: rgb(230, 245, 240);">
            <view>{{item.cost}}元/公里</view>
            <view>{{item.costLiter}}升</view>
            <view>+{{item.diffMile}}公里</view>
          </view>
        </view>
      </view>
    </view>
  </view>
</scroll-view>